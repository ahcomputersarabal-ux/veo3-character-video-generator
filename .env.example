# Google Cloud Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_CLOUD_BUCKET=veo3-videos

# Veo 3 Configuration
VEO3_MODEL=veo3-fast
VEO3_TIMEOUT=300
VEO3_MAX_RETRIES=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
CACHE_DIR=./cache

# Character Settings
CHARACTER_CONSISTENCY_THRESHOLD=0.85
CHARACTER_MAX_REFERENCES=10

# Video Settings
VIDEO_DEFAULT_DURATION=6
VIDEO_DEFAULT_RESOLUTION=4K
VIDEO_ASPECT_RATIO=16:9

# Logging
LOG_LEVEL=INFO

# Security
SECRET_KEY=your_secret_key_here
